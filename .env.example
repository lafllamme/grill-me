# Nuxt runtime config (server-only)
NUXT_CF_ACCOUNT_ID=
NUXT_CF_API_TOKEN=
NUXT_CF_AI_MODEL=@cf/qwen/qwen3-30b-a3b-fp8
NUXT_GITHUB_TOKEN=
NUXT_CF_AI_TIMEOUT_MS=30000
NUXT_CF_AI_MAX_TOKENS=240
NUXT_GITHUB_TIMEOUT_MS=12000
